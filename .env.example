# LeadFlow — environment template (do not commit real `.env` files)
#
# Where to copy:
# - Local backend + Prisma: save as `backend/.env` (Prisma reads DATABASE_URL from here).
# - Local frontend overrides: optional `frontend/.env` with `VITE_*` only (see README).
# - Docker Compose: sets DATABASE_URL, PORT, and VITE_API_URL in `docker-compose.yml`;
#   you still run migrate/seed yourself after `compose up` (see README).

# --- Backend (`backend/.env`) ---
# PostgreSQL connection string
# Format: postgresql://<user>:<password>@<host>:<port>/<database>[?schema=public]
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/leadflow

# Port the Express backend listens on (default: 5001)
PORT=5001

# Node environment: development | production
NODE_ENV=development

# --- Frontend (`frontend/.env`, optional) ---
# Base URL for the browser to call the API (Vite injects at dev/build time).
# Default in code matches this if unset.
VITE_API_URL=http://localhost:5001/api
