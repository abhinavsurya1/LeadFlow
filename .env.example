# LeadFlow — environment template (do not commit real `.env` files)
#
# Where to copy:
# - Repo root `.env` — optional; Compose reads this for variable substitution (Postgres ports, etc.).
# - `backend/.env` — local Prisma + Express (`DATABASE_URL`).
# - `frontend/.env` — optional `VITE_*` overrides for local `npm run dev`.

# --- Backend (`backend/.env`) ---
# PostgreSQL connection string
# Format: postgresql://<user>:<password>@<host>:<port>/<database>[?schema=public]
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/leadflow

# Port the Express backend listens on (default: 5001)
PORT=5001

# Node environment: development | production
NODE_ENV=development

# --- Frontend (`frontend/.env`, optional) ---
# Base URL for the browser to call the API (Vite injects at dev/build time).
# Default in code matches this if unset.
VITE_API_URL=http://localhost:5001/api

# --- Docker Compose (optional root `.env`; defaults match below) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=leadflow
POSTGRES_PORT=5432
BACKEND_PORT=5001
FRONTEND_DEV_PORT=5173
# Production-like compose (`docker-compose.prod.yml`) nginx → host port
FRONTEND_PORT=8080
