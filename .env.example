# Backend
# PostgreSQL connection string
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/leadflow

# Port the Express backend listens on (default: 5001)
PORT=5001

# Node environment: development | production
NODE_ENV=development

# Frontend
# Base URL of the backend API, consumed by Vite at build time
# In Docker, this is handled by the nginx proxy — leave blank or set to /api
VITE_API_URL=http://localhost:5001/api
